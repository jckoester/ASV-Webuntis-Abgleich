# Kopie als `.env` anlegen und ausfüllen. `.env` ist in .gitignore.
#
# TENANT_ID + CLIENT_ID ablesen in:
#   WebUntis → Administration → Plattform → IServ → Abschnitt "Zugangsdaten"
# PASSWORT (Secret): NICHT in WebUntis sichtbar (dort nur "zurücksetzen" —
#   NICHT klicken, das bricht die IServ-Sync!). Stattdessen den bereits in
#   IServ hinterlegten Wert übernehmen (IServ → Verwaltung → System →
#   Konfiguration → WebUntis) ODER eine eigene Plattform-Applikation (Moodle)
#   einrichten, die beim Speichern ein frisches Passwort anzeigt.

UNTIS_TENANT_ID=
UNTIS_CLIENT_ID=
UNTIS_CLIENT_SECRET=

# Gateway. Falls OneRoster 404 liefert, hier testweise den Schulhost
# https://ggd.webuntis.com eintragen. Token-Host bleibt der Gateway.
UNTIS_API_BASE=https://api.webuntis.com
UNTIS_TOKEN_BASE=https://api.webuntis.com
